# ============================================================
# Texas A&M Symplicity Job Notifier — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# --- TAMU SSO Credentials ---
TAMU_USERNAME=your_netid@tamu.edu
TAMU_PASSWORD=your_password_here

# --- Discord Webhook URL ---
# Create one in: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# --- Optional Tuning ---
# How many pages of results to scrape (default: 3)
MAX_PAGES=3

# Headless mode for Playwright: true = no browser window, false = visible (useful for first auth)
HEADLESS=true

# --- Fuzzy Matching & Client-side Filters ---
# Comma-separated list of target locations (substring or fuzzy). Leave empty to disable location filtering.
# E.g. LOCATION_FILTER=College Station, Remote
LOCATION_FILTER=

# Fuzzy similarity threshold (0 to 100). Higher is stricter. Default is 80.
FUZZY_THRESHOLD=80

# --- Academic Level Filtering ---
# Target academic level for filtering. Options: undergraduate, masters, phd, all
MY_ACADEMIC_LEVEL=undergraduate

# --- Loop Interval ---
# How often to check for jobs in continuous loop mode (in minutes). Default: 60 (1 hour).
RUN_INTERVAL_MINS=60


